func downloadResumeHandler(w http.ResponseWriter, r *http.Request){
	role, ok := r.Context().Value("role").(string)

	if !ok || role != "recruiter"{
		http.Error(w,"FORBIDDEN",http.StatusForbidden)
		return
	}

	recruiterID := r.Context().Value("user_id").(string)

	parts := strings.Split(r.URL.Path,"/")
	if len(parts) < 4{
		http.Error(w,"INVALID URL",http.StatusBadRequest)
		return
	}

	applicationID := parts[2]

	var s3Key string
	err := db.QueryRow(`
		SELECT a.resume_url
		FROM applications a
		JOIN jobs j ON a.job_id = j.id
		WHERE a.id = $1 AND j.recruiter_id = $2
	`, applicationID, recruiterID).Scan(&s3Key)

	if err!=nil {
		fmt.Print(err)
		http.Error(w,"APPLICATION NOT FOUND",http.StatusNotFound)
		return
	}

	presigner := s3.NewPresignClient(s3Client)

	req, err := presigner.PresignGetObject(
		context.TODO(),
		&s3.GetObjectInput{
			Bucket: &bucketName,
			Key: &s3Key,
		},
		s3.WithPresignExpires(10*time.Minute),
	)

	if err!= nil{
		http.Error(w,"FAILED TO GENERATE DOWNLOAD URL",http.StatusInternalServerError)
		return
	}

	json.NewEncoder(w).Encode(map[string]string{
		"download_url":req.URL,
	})
}

func presignApplicationResumeUpload(w http.ResponseWriter, r *http.Request){

	log.Println("JWT user_id:", r.Context().Value("user_id"))
log.Println("JWT role:", r.Context().Value("role"))
log.Println("Full path:", r.URL.Path)

	role, ok := r.Context().Value("role").(string)
	if !ok || role!="candidate"{
		http.Error(w,"FORBIDDEN",http.StatusForbidden)
		return
	}

	candidateID := r.Context().Value("user_id").(string)


	parts := strings.Split(r.URL.Path,"/")
	if len(parts) < 5{
		http.Error(w,"INVALID URL",http.StatusBadRequest)
		return
	}
	
	applicationID := parts[2]

	var existingResume sql.NullString

	err := db.QueryRow(`
    SELECT resume_url
    FROM applications
    WHERE id = $1 AND candidate_id = $2
`, applicationID, candidateID).Scan(&existingResume)


	if err != nil {
		http.Error(w,"APLLICATION NOT FOUND",http.StatusNotFound)
		return
	}

	if existingResume.Valid{
		http.Error(w,"RESUME ALREADY UPLOADED FOR THIS APPLICATION",http.StatusConflict)
		return
	}

	//BUILDING S3 KEY

	s3Key := fmt.Sprintf("resumes/%s/resume.pdf",applicationID) //location name inside S3

	presigner := s3.NewPresignClient(s3Client)

	req, err := presigner.PresignPutObject( //generating a temporary permission
		context.TODO(),
		&s3.PutObjectInput{
			Bucket: &bucketName,
			Key: &s3Key,
			ContentType: aws.String("application/pdf"),
		},
		s3.WithPresignExpires(10*time.Minute),
	)

	if err!=nil{
		http.Error(w,"FAILED TO GENERATE UPLOAD URL",http.StatusInternalServerError)
		return
	}

	json.NewEncoder(w).Encode(map[string]string{
		"upload_url":req.URL,
		"s3_key":s3Key,
	})
}



func confirmResumeUploadHandler(w http.ResponseWriter,r *http.Request){
	role := r.Context().Value("role").(string)

	if role != "candidate" {
		http.Error(w, "FORBIDDEN", http.StatusForbidden)
		return
	}
		
	candidateID := r.Context().Value("user_id").(string)

	parts := strings.Split(r.URL.Path,"/")
	if len(parts)<5{
		http.Error(w,"INVALID URL",http.StatusBadRequest)
		return
	}

	applicationID := parts[2]

	s3Key := fmt.Sprintf("resumes/%s/resume.pdf",applicationID)

	res, err := db.Exec(`
		UPDATE applications
		SET resume_url = $1,
		    status = 'resume_uploaded'
		WHERE id = $2 AND candidate_id = $3
	`, s3Key, applicationID, candidateID)

	if err != nil{
		http.Error(w,"FAILED TO UPDATE APPLICATION",http.StatusInternalServerError)
		return
	}

	rows, _ := res.RowsAffected()

	if rows == 0{
		http.Error(w,"APPLICATION NOT FOUND",http.StatusNotFound)
		return
	}

	json.NewEncoder(w).Encode(map[string]string{
		"message": "RESUME UPLOAD CONFIRMED",
	})


}



func updateApplicationStatusHandler(w http.ResponseWriter, r *http.Request){
	if r.Method != http.MethodPatch{
		http.Error(w,"METHOD NOT ALLOWED",http.StatusMethodNotAllowed)
		return
	}

	role := r.Context().Value("role").(string)

	if role != "recruiter"{
		http.Error(w,"FORBIDDEN",http.StatusForbidden)
		return
	}

	recruiterID := r.Context().Value("user_id").(string)

	parts := strings.Split(r.URL.Path,"/")

	if len(parts) <4{
		http.Error(w,"INVALID URL",http.StatusBadRequest)
		return
	}
	applicationID := parts[2]

	var body struct{
		Status string `json:"status"`
	}

	if err := json.NewDecoder(r.Body).Decode(&body); err != nil{
		http.Error(w,"INVALID BODY",http.StatusBadRequest)
		return
	}

	if !allowedStatuses[body.Status]{
		http.Error(w,"INVALID STATUS",http.StatusBadRequest)
		return
	}

	res, err := db.Exec(`
		UPDATE applications a
		SET status = $1
		FROM jobs j
		WHERE a.id = $2
		  AND a.job_id = j.id
		  AND j.recruiter_id = $3
		 `,body.Status,applicationID,recruiterID)

	if err != nil{
		log.Println("STATUS UPDATE ERROR:",err)
		http.Error(w,"FAIELD TO UPDATE STATUS",http.StatusInternalServerError)
		return
	}

	rows, _ := res.RowsAffected()

	if rows == 0{
		http.Error(w,"APPLICATION NOT FOUND OR NOT AUTHORIZED",http.StatusForbidden)
		return
	}

	json.NewEncoder(w).Encode(map[string]string{
		"message": "STATUS UPDATED",
		"status": body.Status,
	})
}