func applicationSubRouter(w http.ResponseWriter,r *http.Request){
	path := r.URL.Path

	if strings.HasSuffix(path,"/resume/presign"){
		presignApplicationResumeUpload(w,r)
		return
	}

	if strings.HasSuffix(path,"/resume/confirm") && r.Method == http.MethodPost{
		confirmResumeUploadHandler(w,r)
		return
	}

	if strings.HasSuffix(path,"status") && r.Method == http.MethodPatch{
		updateApplicationStatusHandler(w,r)
		return
	}

	if strings.HasSuffix(path,"/resume") && r.Method == http.MethodGet{
		downloadResumeHandler(w,r)
		return
	}


	http.Error(w,"NOT FOUND",http.StatusNotFound)
} 


func jobIdHandler(w http.ResponseWriter, r *http.Request){
	if r.Method != http.MethodGet{
		http.Error(w,"Method Not Allowed",http.StatusMethodNotAllowed)
		return
	}

	id := strings.TrimPrefix(r.URL.Path,"/jobs/")

	if id == ""{
		http.Error(w,"JOB ID REQUIRED",http.StatusBadRequest)
		return
	}

	var job Job

	err:= db.QueryRow(
		`SELECT
			id,
			title,
			description,
			recruiter_id,
			status,
			deadline,
			created_at
		FROM jobs
		WHERE id = $1`,  //$1->PLACEHOLDER
		id,
	).Scan(
		&job.ID,
		&job.Title,
		&job.Description,
		&job.RecruiterID,
		&job.Status,
		&job.Deadline,
		&job.CreatedAt,
	)

	if err == sql.ErrNoRows{
		http.Error(w,"JOB NOT FOUND",http.StatusNotFound)
		return
	}

	if err != nil {
		http.Error(w,"FAILED TO FETCH JOB",http.StatusInternalServerError)
		return
	}

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(job)
}



func applyJobHandler(w http.ResponseWriter, r *http.Request){
	if r.Method != http.MethodPost{
		http.Error(w,"METHOD NOT ALLOWED",http.StatusMethodNotAllowed)
		return
	}

	role, ok := r.Context().Value("role").(string)

	if !ok {
		http.Error(w,"UNAUTHORIZED",http.StatusUnauthorized)
		return
	}

	if role!= "candidate"{
		http.Error(w,"FORBIDDEN: CANDIDATES ONLY",http.StatusForbidden)
		return
	}

	candidateID, ok := r.Context().Value("user_id").(string)
	if !ok {
		http.Error(w, "UNAUTHORIZED", http.StatusUnauthorized)
		return
	}

	var input struct {
		JobID string `json:"job_id"`
	}

	if err := json.NewDecoder(r.Body).Decode(&input); err != nil {
		http.Error(w,"INVALID REQUEST BODY",http.StatusBadRequest)
		return
	}

	appID := uuid.NewString()

	_, err := db.Exec(`
		INSERT INTO applications (id, job_id, candidate_id,status)
		VALUES ($1, $2, $3,'applied')
	`, appID, input.JobID, candidateID)

	if err!= nil {

		if strings.Contains(err.Error(),"unique"){ // THIS HANDLES DUPLICATES
			http.Error(w,"ALREADY APPLIED TO THIS JOB",http.StatusConflict)
			return
		}

		log.Println("APPLY JOB ERROR: ",err)
		http.Error(w,"FAILED TO APPLY",http.StatusInternalServerError)
		return
	}

	w.WriteHeader(http.StatusCreated)

	json.NewEncoder(w).Encode(map[string]string{
		"application_id": appID,
	})
}

func listApplicationHandler(w http.ResponseWriter, r *http.Request){
	if r.Method != http.MethodGet{
		http.Error(w,"METHOD NOT ALLOWED",http.StatusMethodNotAllowed)
		return
	}

	role, ok := r.Context().Value("role").(string)

	if !ok{
		http.Error(w,"UNAUTHORIZED",http.StatusUnauthorized)
		return
	}

	if role != "recruiter"{
		http.Error(w,"FORBIDDEN: RECRUITERS ONLY",http.StatusForbidden)
		return
	}

	recruiterID, ok := r.Context().Value("user_id").(string)

	if !ok{
		http.Error(w,"UNAUTHORIZED",http.StatusUnauthorized)
		return
	}

	jobID := r.URL.Query().Get("job_id")

	var rows *sql.Rows
	var err error

	if jobID != "" {
		
		rows, err = db.Query(`
			SELECT a.id, a.job_id, a.candidate_id, a.applied_at
			FROM applications a
			JOIN jobs j ON a.job_id = j.id
			WHERE j.recruiter_id = $1 AND j.id = $2
		`, recruiterID, jobID)
	} else {
		
		rows, err = db.Query(`
			SELECT a.id, a.job_id, a.candidate_id, a.applied_at
			FROM applications a
			JOIN jobs j ON a.job_id = j.id
			WHERE j.recruiter_id = $1
		`, recruiterID)
	}

	if err != nil {
		log.Println("LIST APPLICATIONS ERROR:",err)
		http.Error(w,"FAILED TO FETCH APPLICATIONS",http.StatusInternalServerError)
		return
	}

	defer rows.Close() //if you dot call this the DB conncn stays open
					   //defer - tells go to run this line later when the func is about to finish
	

	type ApplicationResponse struct{
		ApplicationID string    `json:"application_id"`
		JobID         string    `json:"job_id"`
		CandidateID   string    `json:"candidate_id"`
		AppliedAt     time.Time `json:"applied_at"` 
	}

 var applications  []ApplicationResponse

	for rows.Next(){
		var app ApplicationResponse
		if err := rows.Scan(&app.ApplicationID,&app.JobID,&app.CandidateID,&app.AppliedAt); err != nil{
			log.Println("ROW SCAN ERROR:",err)
			continue
		}
		applications = append(applications,app)
	}

	w.Header().Set("Content-Type","application/json")
	json.NewEncoder(w).Encode(applications)



}

func applicationsHandler(w http.ResponseWriter, r *http.Request){
	switch r.Method {
	case http.MethodGet:
		listApplicationHandler(w,r)
	case http.MethodPost:
		applyJobHandler(w,r)
	
default:
	http.Error(w,"METHOD NOT ALLOWED",http.StatusMethodNotAllowed)
}
}


